generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Settings {
  id              String   @id @default(cuid())
  siteName        String   @default("Skeleton")
  siteLogo        String?
  siteDescription String?
  primaryColor    String   @default("#3b82f6")
  unitStatusConfig Json    @default("{}")
  wordpressConfig Json     @default("{}")
  hubspotConfig   Json     @default("{}")
  updatedAt       DateTime @updatedAt

  @@map("settings")
}

model users {
  id                 BigInt      @id @default(autoincrement())
  username           String?     @unique @db.VarChar(12)
  email              String      @unique @db.VarChar(255)
  password           String      @db.VarChar(255)
  authLevel          Int         @default(1)
  roleId             Int?
  banned             Boolean     @default(false)
  active             Boolean     @default(true)
  passwdRecoveryCode String?     @db.VarChar(60)
  passwdRecoveryDate DateTime?
  passwdModifiedAt   DateTime?
  lastLogin          DateTime?
  createdAt          DateTime    @default(now())
  modifiedAt         DateTime    @updatedAt
  role               Role?       @relation(fields: [roleId], references: [id])
  activities         activities[]

  @@map("users")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(50)
  label       String   @db.VarChar(255)
  description String?
  isSystem    Boolean  @default(false)
  permissions Json     @default("{}")
  priority    Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  modifiedAt  DateTime @updatedAt
  users       users[]

  @@index([name])
  @@index([priority])
  @@map("roles")
}

model activities {
  id          Int      @id @default(autoincrement())
  userId      BigInt
  type        String   @db.VarChar(50)
  title       String   @db.VarChar(255)
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())
  user        users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@map("activities")
}

model Location {
  id             String    @id @default(cuid())
  name           String
  slug           String    @unique
  code           String?   @unique
  addressLine1   String?
  addressLine2   String?
  townCity       String?
  county         String?
  postcode       String?
  email          String?
  phone          String?
  openingHours   String?
  latitude       Decimal?  @db.Decimal(10, 7)
  longitude      Decimal?  @db.Decimal(10, 7)
  active         Boolean   @default(true)
  legacyId       Int?      @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    BigInt?
  updatedById    BigInt?
  units          Unit[]
  contracts      Contract[]
  areas          LocationArea[]

  @@index([name])
  @@index([active])
  @@map("locations")
}

model Client {
  id               String      @id @default(cuid())
  legacyId         Int?        @unique
  status           ClientStatus @default(ACTIVE)
  companyName      String?
  firstName        String
  lastName         String
  email            String?
  phone            String?
  billingEmail     String?
  notes            String?
  addressLine1     String?
  addressLine2     String?
  townCity         String?
  county           String?
  postcode         String?
  country          String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  createdById      BigInt?
  updatedById      BigInt?
  contracts        Contract[]
  hubSpotDeals     HubSpotDeal[] @relation("HubSpotDealClient")

  @@index([status])
  @@index([email])
  @@index([lastName, firstName])
  @@map("clients")
}

model Unit {
  id                String     @id @default(cuid())
  legacyId          Int?       @unique
  locationId        String
  code              String
  unitNumber        Int?
  name              String?
  type              String?
  sizeSqft          Int?
  dimensions        String?
  weeklyRate        Decimal?   @db.Decimal(10, 2)
  monthlyRate       Decimal?   @db.Decimal(10, 2)
  salePrice         Decimal?   @db.Decimal(10, 2)
  offer             String?
  is24hDriveUp      Boolean    @default(false)
  isIndoor          Boolean    @default(false)
  status            UnitStatus @default(AVAILABLE)
  active            Boolean    @default(true)
  description       String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  createdById       BigInt?
  updatedById       BigInt?
  location          Location   @relation(fields: [locationId], references: [id], onDelete: Restrict)
  contracts         Contract[]
  areaPlacements    UnitAreaPlacement[]

  @@index([status])
  @@index([active])
  @@index([locationId])
  @@index([locationId, sizeSqft])
  @@unique([locationId, sizeSqft, unitNumber])
  @@map("units")
}

model Contract {
  id                 String          @id @default(cuid())
  contractNumber     String          @unique
  legacyId           Int?            @unique
  status             ContractStatus  @default(DRAFT)
  clientId           String
  unitId             String
  locationId         String
  startDate          DateTime
  endDate            DateTime?
  billingDay         Int?
  weeklyRate         Decimal?        @db.Decimal(10, 2)
  monthlyRate        Decimal?        @db.Decimal(10, 2)
  depositAmount      Decimal?        @db.Decimal(10, 2)
  paymentMethod      String?
  signedAt           DateTime?
  notes              String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  createdById        BigInt?
  updatedById        BigInt?
  client             Client          @relation(fields: [clientId], references: [id], onDelete: Restrict)
  unit               Unit            @relation(fields: [unitId], references: [id], onDelete: Restrict)
  location           Location        @relation(fields: [locationId], references: [id], onDelete: Restrict)
  hubSpotDeals       HubSpotDeal[]

  @@index([clientId])
  @@index([unitId])
  @@index([locationId])
  @@index([status])
  @@index([startDate])
  @@map("contracts")
}

model LocationArea {
  id                 String              @id @default(cuid())
  locationId         String
  name               String
  description        String?
  backgroundImageUrl String?
  canvasWidth        Int                 @default(1400)
  canvasHeight       Int                 @default(820)
  sortOrder          Int                 @default(0)
  active             Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  location           Location            @relation(fields: [locationId], references: [id], onDelete: Cascade)
  placements         UnitAreaPlacement[]

  @@index([locationId, sortOrder])
  @@map("location_areas")
}

model UnitAreaPlacement {
  id          String         @id @default(cuid())
  areaId      String
  unitId      String
  shape       PlacementShape @default(RECTANGLE)
  x           Float
  y           Float
  width       Float
  height      Float
  rotation    Float          @default(0)
  zIndex      Int            @default(0)
  label       String?
  points      Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  area        LocationArea   @relation(fields: [areaId], references: [id], onDelete: Cascade)
  unit        Unit           @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([areaId, zIndex])
  @@index([unitId])
  @@map("unit_area_placements")
}

enum ActivityType {
  LOGIN
  LOGOUT
  PASSWORD_CHANGE
  PROFILE_UPDATE
}

enum UnitStatus {
  AVAILABLE
  RESERVED
  OCCUPIED
  MAINTENANCE
  INACTIVE
}

enum ContractStatus {
  DRAFT
  PENDING_SIGNATURE
  ACTIVE
  TERMINATED
  EXPIRED
  CANCELLED
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  LEAD
}

enum PlacementShape {
  RECTANGLE
  POLYGON
}

model HubSpotDeal {
  id             String    @id
  dealName       String
  amount         Decimal?  @db.Decimal(12, 2)
  dealStage      String
  pipeline       String
  closeDate      DateTime?
  owner          String?
  clientId       String?
  contractId     String?
  importedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  rawData        Json
  lastSyncedAt   DateTime  @default(now())

  client         Client?   @relation("HubSpotDealClient", fields: [clientId], references: [id])
  contract       Contract? @relation(fields: [contractId], references: [id])

  @@index([dealStage])
  @@index([pipeline])
  @@index([closeDate])
  @@index([clientId])
  @@index([contractId])
  @@map("hubspot_deals")
}
